---
interface Props {
  n: string;
  title: string;
  dek?: string;
  id?: string;
}

const { n, title, dek, id } = Astro.props;
const anchor = id ?? `chapter-${n}`;
---

<section id={anchor} class="stage-marker scroll-mt-24">
  <hr class="stage-marker-rule" aria-hidden="true" />
  <div class="stage-marker-content">
    <span class="stage-marker-num">{n}</span>
    <h2 class="stage-marker-title">{title}</h2>
    {dek && <p class="stage-marker-dek">{dek}</p>}
  </div>
</section>

<style>
  .stage-marker-rule {
    border: 0;
    height: 1px;
    background-color: rgba(11, 11, 14, 0.15);
    margin: 0;
    width: 100%;
  }
  .stage-marker-content {
    padding-top: 2.25rem;
  }
  @media (min-width: 768px) {
    .stage-marker-content {
      padding-top: 3rem;
    }
  }
  .stage-marker-num {
    display: block;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute, #6B6B70);
    margin-bottom: 1rem;
  }
  .stage-marker-title {
    font-family: 'Switzer', ui-sans-serif, system-ui, sans-serif;
    font-weight: 400;
    color: var(--ink, #0B0B0E);
    margin: 0;
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .stage-marker-dek {
    margin: 0.85rem 0 0;
    font-size: 1.0625rem;
    line-height: 1.5;
    max-width: 56ch;
    color: var(--mute, #6B6B70);
  }
</style>
