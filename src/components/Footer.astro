---
const year = new Date().getFullYear();
---

<footer id="contact" class="border-t border-ink/15 bg-paper text-ink">
  <div class="mx-auto max-w-[1600px] px-6 py-16 md:px-10 md:py-24">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      <div class="md:col-span-7">
        <p class="font-display text-4xl leading-[1.05] md:text-6xl">
          Like the work?
          <br />
          <a
            href="mailto:t.cohen2002@gmail.com"
            class="underline decoration-1 underline-offset-[0.18em] hover:text-clay"
          >
            Let's talk.
          </a>
        </p>
      </div>

      <div class="grid grid-cols-2 gap-x-10 gap-y-6 md:col-span-5 md:grid-cols-2 md:gap-x-6">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mute">Email</p>
          <a
            href="mailto:t.cohen2002@gmail.com"
            class="mt-2 block underline decoration-1 underline-offset-[0.18em]"
          >
            t.cohen2002@gmail.com
          </a>
        </div>
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mute">Elsewhere</p>
          <a
            href="https://www.linkedin.com/in/tal-cohen-74b126338"
            target="_blank"
            rel="noopener"
            class="mt-2 block underline decoration-1 underline-offset-[0.18em]"
          >
            LinkedIn ↗
          </a>
        </div>
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mute">Based</p>
          <p class="mt-2">Sydney · open to relocate</p>
        </div>
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mute">Status</p>
          <p class="mt-2 flex items-center gap-2">
            <span class="relative inline-flex h-2 w-2" aria-hidden="true">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style="background-color: #22C55E;"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full" style="background-color: #22C55E;"></span>
            </span>
            Open to work
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-ink/15">
    <div class="mx-auto flex max-w-[1600px] flex-col gap-2 px-6 py-6 font-mono text-xs uppercase tracking-[0.18em] text-mute md:flex-row md:items-center md:justify-between md:px-10">
      <span>© {year} Tal Cohen</span>
      <span>Designed &amp; built in Sydney · Hola · Hello · G'day</span>
    </div>
  </div>
</footer>
