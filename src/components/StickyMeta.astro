---
interface Props {
  role: string;
  team?: string;
  year: string;
  duration?: string;
  outcome: string;
  tools: string[];
}

const { role, team, year, duration, outcome, tools } = Astro.props;

const rows: Array<{ label: string; value: string }> = [
  { label: 'Role', value: role },
  ...(team ? [{ label: 'Team', value: team }] : []),
  { label: 'Year', value: year },
  ...(duration ? [{ label: 'Duration', value: duration }] : []),
  { label: 'Outcome', value: outcome },
  { label: 'Tools', value: tools.join(' · ') },
];
---

<aside class="md:sticky md:top-24 md:self-start">
  <dl class="grid grid-cols-2 gap-x-6 gap-y-5 md:grid-cols-1 md:gap-y-6">
    {rows.map((r) => (
      <div>
        <dt class="font-mono text-[11px] uppercase tracking-[0.18em] text-mute md:text-[12px]">
          {r.label}
        </dt>
        <dd class="mt-1 text-sm leading-snug text-ink md:text-base">
          {r.value}
        </dd>
      </div>
    ))}
  </dl>
</aside>
