<figure class="three-continents" aria-label="Three continents: Mallorca, Charleston, Sydney">
  <svg
    viewBox="0 0 220 130"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    class="three-continents__svg"
  >
    <title>Mallorca · Charleston · Sydney</title>

    <path
      d="M 45 52 Q 75 24 108 38 Q 145 60 178 92"
      fill="none"
      stroke="currentColor"
      stroke-width="0.7"
      stroke-dasharray="2 3"
      opacity="0.35"
    />

    <g>
      <circle cx="45" cy="52" r="3.5" fill="#C9633F" />
      <text x="40" y="55" text-anchor="end" class="three-continents__label">Charleston</text>
    </g>

    <g>
      <circle cx="108" cy="38" r="3.5" fill="#C9633F" />
      <text x="108" y="27" text-anchor="middle" class="three-continents__label">Mallorca</text>
    </g>

    <g>
      <circle cx="178" cy="92" r="3.5" fill="#C9633F" />
      <text x="183" y="95" text-anchor="start" class="three-continents__label">Sydney</text>
    </g>
  </svg>

  <figcaption class="three-continents__caption">Three continents · one practice</figcaption>
</figure>

<style>
  .three-continents {
    margin: 0;
    max-width: 240px;
  }
  .three-continents__svg {
    width: 100%;
    height: auto;
    display: block;
    color: var(--ink, #0B0B0E);
  }
  .three-continents__label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 7px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    fill: rgba(11, 11, 14, 0.6);
  }
  .three-continents__caption {
    margin-top: 0.9rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(11, 11, 14, 0.5);
  }
</style>
