---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  n: string;
  title: string;
  tagline: string;
  description?: string;
  year: string;
  duration?: string;
  role: string;
  team?: string;
  tools: string[];
  outcome: string;
  cover: ImageMetadata;
  coverAlt: string;
  coverFullBleed?: boolean;
  accent: string;
  titleColor?: string;
  figmaUrl?: string;
}

const {
  n,
  title,
  tagline,
  description,
  year,
  duration,
  role,
  team,
  tools,
  outcome,
  cover,
  coverAlt,
  coverFullBleed,
  accent,
  titleColor,
  figmaUrl,
} = Astro.props;

const projectAccent = titleColor ?? 'var(--ink)';
const meta = [
  { label: 'Year', value: year },
  duration ? { label: 'Duration', value: duration } : null,
  { label: 'Role', value: role },
  team ? { label: 'Team', value: team } : null,
  { label: 'Tools', value: tools.join(' · ') },
  { label: 'Outcome', value: outcome },
].filter(Boolean) as { label: string; value: string }[];
---

<header class="cs-hero">
  <div class="cs-hero-inner">
    <div class="cs-hero-top">
      <div class="cs-hero-left">
        <div class="cs-hero-eyebrow" style={`color: ${projectAccent};`}>
          <span>{n}</span>
          <span aria-hidden="true">·</span>
          <span>{year}</span>
          <span aria-hidden="true">·</span>
          <span>Univ. of Sydney</span>
        </div>

        <h1 class="cs-hero-title">{title}</h1>

        <p class="cs-hero-tagline">{tagline}</p>

        {description && (
          <p class="cs-hero-description">{description}</p>
        )}

        {figmaUrl && (
          <a
            class="cs-hero-cta"
            href={figmaUrl}
            target="_blank"
            rel="noopener"
            style={`color: ${projectAccent}; border-color: ${projectAccent};`}
          >
            View Prototype
          </a>
        )}
      </div>

      <dl class="cs-hero-meta">
        {meta.map(({ label, value }) => (
          <div class="cs-hero-meta-row">
            <dt style={`color: ${projectAccent};`}>{label}</dt>
            <dd>{value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div
      class:list={['cs-hero-image-card', coverFullBleed && 'cs-hero-image-card--fullbleed']}
      style={`background-color: ${accent};`}
    >
      <Image
        src={cover}
        alt={coverAlt}
        widths={[640, 1280, 1920, 2560]}
        sizes={coverFullBleed ? '(min-width: 1024px) 2200px, 100vw' : '(min-width: 1024px) 960px, 90vw'}
        class="cs-hero-image"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</header>

<style>
  .cs-hero {
    padding-top: clamp(5rem, 7vh, 6.5rem);
    padding-bottom: 2.5rem;
  }
  .cs-hero-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
  @media (min-width: 768px) {
    .cs-hero-inner {
      padding-inline: 3rem;
    }
  }

  .cs-hero-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }
  @media (min-width: 900px) {
    .cs-hero-top {
      grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
      gap: 4rem;
      align-items: start;
      margin-bottom: 3.5rem;
    }
  }

  .cs-hero-eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .cs-hero-title {
    margin: 0;
    font-family: 'Switzer', ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
    font-size: clamp(4.5rem, 10vw, 8.5rem);
    line-height: 0.9;
    letter-spacing: -0.045em;
    color: var(--ink, #0B0B0E);
  }

  .cs-hero-tagline {
    margin: 1.4rem 0 0;
    font-family: 'Switzer', ui-sans-serif, system-ui, sans-serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.25rem, 1.85vw, 1.625rem);
    line-height: 1.3;
    color: var(--ink, #0B0B0E);
    max-width: 44ch;
  }

  .cs-hero-description {
    margin: 1.25rem 0 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink, #0B0B0E);
    max-width: 52ch;
  }

  .cs-hero-cta {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.85rem 1.6rem;
    border: 1px solid currentColor;
    border-radius: 999px;
    font-family: 'Switzer', ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background-color 200ms ease;
  }
  .cs-hero-cta:hover {
    background-color: rgba(0, 0, 0, 0.04);
  }

  .cs-hero-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-self: end;
    padding-top: 0.4rem;
  }
  @media (min-width: 900px) {
    .cs-hero-meta {
      padding-top: 2.5rem;
    }
  }
  .cs-hero-meta-row {
    display: grid;
    grid-template-columns: minmax(7rem, 0.9fr) minmax(0, 2fr);
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.75rem;
    border-bottom: 1px solid rgba(11, 11, 14, 0.12);
  }
  .cs-hero-meta-row:first-child {
    border-top: 1px solid rgba(11, 11, 14, 0.12);
  }
  .cs-hero-meta dt {
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .cs-hero-meta dd {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.45;
    color: var(--ink, #0B0B0E);
  }

  .cs-hero-image-card {
    border-radius: 18px;
    padding: clamp(1.5rem, 4vw, 3.5rem) clamp(1.5rem, 4vw, 3.5rem);
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .cs-hero-image-card {
      border-radius: 24px;
    }
  }
  .cs-hero-image {
    max-width: 100%;
    width: auto;
    height: auto;
    max-height: 64vh;
    display: block;
    background: transparent;
  }

  .cs-hero-image-card--fullbleed {
    padding: 0;
    aspect-ratio: 16 / 9;
  }
  .cs-hero-image-card--fullbleed .cs-hero-image {
    width: 100%;
    height: 100%;
    max-height: none;
    object-fit: cover;
    object-position: 50% 55%;
  }
</style>
