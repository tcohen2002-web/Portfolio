---
const { pathname } = Astro.url;
const isHome = pathname === '/';

const links = [
  { href: '/', label: 'Home' },
  { href: '/#work', label: 'Works' },
  { href: '/#contact', label: 'Contact' },
];
---

<nav
  id="site-nav"
  aria-label="Primary"
  class="fixed inset-x-0 top-0 z-50 bg-paper"
>
  <div class="relative mx-auto max-w-[1600px] px-6 py-5 md:px-10 md:py-0">
    {isHome ? (
      <a
        href="/"
        aria-label="Tal Cohen — Home"
        data-hero-link
        class="absolute left-6 md:left-10 z-10 block select-none text-ink"
        style="top: var(--hero-top, 18vh);"
      >
        <span
          data-hero-stack
          class="relative inline-block font-sans font-medium uppercase leading-[0.85] tracking-[-0.04em]"
          style="font-size: var(--hero-font-size, 22vw); transform-origin: 0 0; will-change: transform;"
        >
          <span data-tal class="inline-block">
            <span class="letter" style="--c:#8478C4">T</span><span class="letter" style="--c:#7A9670">a</span><span class="letter" style="--c:#C4A82E">l</span>
          </span>
          <span data-cohen class="block" style="will-change: transform;">
            <span class="letter" style="--c:#C9633F">C</span><span class="letter" style="--c:#8478C4">o</span><span class="letter" style="--c:#7A9670">h</span><span class="letter" style="--c:#C4A82E">e</span><span class="letter" style="--c:#C9633F">n</span>
          </span>
        </span>
      </a>
    ) : (
      <a href="/" aria-label="Tal Cohen — Home" class="absolute left-6 md:left-10 top-5 md:top-5 z-10 block select-none whitespace-nowrap font-sans font-medium uppercase leading-[0.85] tracking-[-0.04em] text-ink hover:opacity-60 text-[15px] md:text-[28px]">
        Tal Cohen
      </a>
    )}

    <ul class="flex items-center justify-end gap-4 font-mono text-[11px] uppercase tracking-[0.18em] text-ink md:gap-6 md:py-5 md:text-[12px]">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={[
              'transition-opacity hover:opacity-60',
              pathname === l.href && 'opacity-50',
            ]}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style is:global>
  html { scroll-behavior: smooth; }
  :root { --hero-top: 20px; --hero-font-size: 18vw; }
  @media (max-width: 767px) {
    :root { --hero-top: 10vh; --hero-font-size: 25vw; }
  }
</style>

<style>
  .letter { transition: color 280ms ease; }
  @media (hover: hover) and (min-width: 768px) {
    .letter:hover { color: var(--c); }
  }
  [data-hero-stack][data-shrunk] .letter { pointer-events: none; }
  [data-hero-stack][data-shrunk] .letter:hover { color: inherit; }
</style>

<script>
  function initHero() {
    const heroLink = document.querySelector<HTMLElement>('[data-hero-link]');
    const heroStack = document.querySelector<HTMLElement>('[data-hero-stack]');
    const talEl = document.querySelector<HTMLElement>('[data-tal]');
    const cohenEl = document.querySelector<HTMLElement>('[data-cohen]');
    const root = document.documentElement;

    if (!heroLink || !heroStack || !talEl || !cohenEl) {
      root.style.removeProperty('--hero-font-size');
      root.style.removeProperty('--hero-top');
      return;
    }

    let targetPx = 28;
    let startPx = 0;
    let isMobile = false;
    let startTopPx = 0;
    let endTopPx = 20;
    let talRatio = 1.5;
    let animP = 0;
    let animRafId: number | null = null;
    let animStart = 0;
    let animFrom = 0;
    let animTo = 0;
    let animDuration = 650;
    type HeroState = 'big' | 'shrinking' | 'small' | 'expanding';
    let state: HeroState = 'big';
    const clamp = (v: number, a: number, b: number) => Math.min(Math.max(v, a), b);
    const smooth = (t: number) => t * t * (3 - 2 * t);

    const measure = () => {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      isMobile = vw < 768;
      const sizeVw = isMobile ? 25 : 18;
      startPx = (sizeVw / 100) * vw;
      targetPx = isMobile ? 15 : 28;
      startTopPx = isMobile ? vh * 0.10 : 20;
      endTopPx = isMobile ? 22 : 20;
      const prevTransform = cohenEl.style.transform;
      cohenEl.style.transform = 'none';
      root.style.setProperty('--hero-font-size', `${startPx}px`);
      const w = talEl.getBoundingClientRect().width;
      if (w > 0) talRatio = w / startPx;
      cohenEl.style.transform = prevTransform;
    };

    const update = () => {
      const p = clamp(animP, 0, 1);

      const shrinkP = smooth(clamp(p / 0.55, 0, 1));
      const scaleNow = 1 + shrinkP * (targetPx / startPx - 1);

      const riseP = smooth(clamp(p / 0.4, 0, 1));
      const dy = riseP * (endTopPx - startTopPx);

      heroStack.style.transform = `translate3d(0, ${dy.toFixed(2)}px, 0) scale(${scaleNow.toFixed(4)})`;

      if (shrinkP > 0.5) {
        heroStack.setAttribute('data-shrunk', '');
      } else {
        heroStack.removeAttribute('data-shrunk');
      }

      const morphP = smooth(clamp((p - 0.4) / 0.6, 0, 1));
      const liftRatio = isMobile ? 0.8 : 0.86;
      const tx = Math.round(morphP * startPx * (talRatio + 0.22));
      const ty = Math.round(-morphP * startPx * liftRatio);
      cohenEl.style.transform = `translate(${tx}px, ${ty}px)`;
    };

    const controller = new AbortController();
    const { signal } = controller;

    const tickAnim = (now: number) => {
      if (animStart === 0) animStart = now;
      const t = clamp((now - animStart) / animDuration, 0, 1);
      const eased = smooth(t);
      animP = animFrom + (animTo - animFrom) * eased;
      update();
      if (t < 1) {
        animRafId = requestAnimationFrame(tickAnim);
      } else {
        animP = animTo;
        update();
        animRafId = null;
        state = animTo === 1 ? 'small' : 'big';
      }
    };

    const startAnim = (to: 0 | 1, duration: number) => {
      animFrom = animP;
      animTo = to;
      animDuration = duration;
      animStart = 0;
      if (animRafId !== null) cancelAnimationFrame(animRafId);
      animRafId = requestAnimationFrame(tickAnim);
    };

    const readScroll = () => {
      const y = window.scrollY;
      const shrinkAt = isMobile ? 10 : 40;
      const expandAt = isMobile ? 5 : 20;
      if (state === 'big' && y > shrinkAt) {
        state = 'shrinking';
        startAnim(1, 700);
      } else if (state === 'small' && y < expandAt) {
        state = 'expanding';
        startAnim(0, 600);
      }
    };

    document.addEventListener('scroll', readScroll, { passive: true, signal });
    window.addEventListener(
      'resize',
      () => {
        measure();
        update();
      },
      { passive: true, signal }
    );
    document.addEventListener(
      'astro:before-swap',
      () => controller.abort(),
      { once: true }
    );

    const homeLinks = document.querySelectorAll<HTMLAnchorElement>('nav a[href="/"]');
    homeLinks.forEach((link) => {
      link.addEventListener(
        'click',
        (e) => {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        },
        { signal }
      );
    });

    measure();
    if (window.scrollY > 2) {
      animP = 1;
      state = 'small';
    } else {
      animP = 0;
      state = 'big';
    }
    update();
  }

  document.addEventListener('astro:page-load', initHero);
</script>
