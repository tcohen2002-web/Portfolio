---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  side?: 'left' | 'right';
  device?: 'phone' | 'watch';
}

const { src, alt, caption, side = 'right', device = 'phone' } = Astro.props;
const maxH = device === 'phone' ? '440px' : '300px';
---

<div class="screen-showcase">
  <div class="screen-prose">
    <slot />
  </div>
  <figure class="screen-figure" style={`--screen-max-h: ${maxH};`}>
    <Image
      src={src}
      alt={alt}
      widths={[320, 640, 960]}
      sizes="(min-width: 768px) 320px, 70vw"
      class="screen-img"
      loading="lazy"
      decoding="async"
    />
    {caption && <figcaption class="screen-caption">{caption}</figcaption>}
  </figure>
</div>

<style>
  .screen-showcase {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .screen-showcase {
      gap: 2.25rem;
    }
  }
  .screen-prose {
    width: 100%;
    max-width: min(65ch, 640px);
  }
  .screen-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .screen-img {
    max-width: 100%;
    max-height: var(--screen-max-h, 440px);
    width: auto;
    height: auto;
    object-fit: contain;
    background: transparent;
    display: block;
  }
  .screen-caption {
    margin: 1rem 0 0;
    max-width: 32ch;
    font-family: 'Switzer', ui-sans-serif, system-ui, sans-serif;
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--mute, #6B6B70);
  }
</style>
